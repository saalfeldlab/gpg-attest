{
  "manifest_version": 3,
  "name": "attestension",
  "version": "0.1.1",
  "description": "Sign media elements via GnuPG and log signatures.",
  "permissions": ["nativeMessaging", "storage", "contextMenus"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background/service-worker.js",
    "scripts": ["background/service-worker.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "css": ["content/menu.css"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "icons": {
    "16": "icons/authenticity-authentic-16.png",
    "24": "icons/authenticity-authentic-24.png",
    "32": "icons/authenticity-authentic-32.png",
    "64": "icons/authenticity-authentic-64.png",
    "128": "icons/authenticity-authentic-128.png"
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": false
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*.png"],
      "matches": ["<all_urls>"]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "attestension@gpg-attest.org",
      "strict_min_version": "109.0"
    }
  }
}
