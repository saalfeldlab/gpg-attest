# ── Server ───────────────────────────────────────────────────────────────────
# gpg-attest-server
SERVER_PORT=8081
SERVER_HOST=localhost

# Trillian log server (gRPC)
TRILLIAN_HOST=localhost
TRILLIAN_RPC_PORT=8090

# Redis (artifact hash → UUID index)
REDIS_HOST=localhost
REDIS_PORT=6379

# MySQL / MariaDB (Trillian backing store)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=trillian
MYSQL_PASSWORD=trillian
MYSQL_DB=trillian

# ── HTTPS (Caddy reverse proxy) ──────────────────────────────────────────────
HTTPS_PORT=8443

# ── Client / Extension ───────────────────────────────────────────────────────
# URL the browser extension uses to reach gpg-attest-server.
# No trailing slash. Must include scheme and port.
LOG_SERVER=https://gpg-attest.org:8443
